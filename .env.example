# --- market-data (opcional; sin claves se usa mock) ---
MARKET_TIINGO_TOKEN=
MARKET_TWELVEDATA_API_KEY=

# Orden de proveedores: tiingo, twelvedata, mock
MARKET_PROVIDER_ORDER=tiingo,twelvedata,mock

# Segundos desde la última sync OK con Tiingo/Twelve (tabla market.price_sync_meta) antes de
# volver a llamar a la API (por defecto 86400). Para pruebas en segundos: 120–300.
# MARKET_STALE_AFTER_SECONDS=86400

# Mínimo de filas en Postgres para servir cache con sync fresco aunque limit sea mayor (defecto 26).
# MARKET_CACHE_SERVE_MIN_ROWS=26
